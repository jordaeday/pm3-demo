import { ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "PM3 NFC raw bytes";
    // preferred-width: 800px;
    // preferred-height: 480px;

    // The ONLY thing this UI does: display a string of bytes from Rust.
    in property <string> raw-data: "Waiting for data...";
    in property <string> log-data: "";
    in property <string> status: "starting up...";
    in property <string> version-info: "";
    in property <int> read-count: 0;
    in property <int> heartbeat-count: 0;

    VerticalLayout {
        padding: 30px;
        spacing: 8px;

        // Status line at the top.
        Text {
            text: root.status;
            font-size: 14px;
            color: #888;
        }

        Text {
            text: root.version-info;
            font-size: 12px;
            color: #666;
        }

        Text {
            text: "reads: " + root.read-count + " + " + root.heartbeat-count + " hidden heartbeats";
            font-size: 14px;
            color: #888;
        }

        // The actual byte dump. ScrollView so it scrolls when the buffer fills up.
        ScrollView {
            vertical-stretch: 1;
            viewport-y: min(0px, self.height - self.viewport-height);
            Text {
                width: parent.width;
                text: root.raw-data;
                font-family: "monospace";
                font-size: 14px;
                wrap: word-wrap;
            }
        }

        // Decoded log messages from 0xED frames.
        ScrollView {
            height: 150px;
            Text {
                width: parent.width;
                text: root.log-data == "" ? "No log messages yet." : root.log-data;
                font-family: "monospace";
                font-size: 13px;
                color: #4aaa88;
                wrap: word-wrap;
            }
        }
    }
}